# BIP-Pipeline 환경변수 설정
# 이 파일을 .env로 복사하여 사용하세요

# 환경 설정
ENV=docker  # local, docker, production

# PostgreSQL 설정
PG_HOST=bip-postgres
PG_PORT=5432
PG_USER=user
PG_PASSWORD=pw1234
PG_DB=stockdb

# Airflow 설정
AIRFLOW_UID=50000

# DART API (전자공시시스템)
# https://opendart.fss.or.kr/ 에서 발급
DART_API_KEY=your_dart_api_key_here

# OpenMetadata Lineage 자동 등록
# OM_BOT_TOKEN: OM UI → Settings → Bots → ingestion-bot → JWT Token
# 또는 DB에서 복호화: docker exec om-ingestion python3 -c "
#   from cryptography.fernet import Fernet
#   f = Fernet(b'jJ/9sz0g0OHxsfxOoSfdFdmk3ysNmPRnH3TUAbz3IHA=')
#   print(f.decrypt(<fernet_token>.encode()).decode())
# "
OM_HOST=http://openmetadata-server:8585
OM_BOT_TOKEN=

# Wren AI (NL2SQL 시맨틱 레이어)
# OpenAI API Key (GPT-4o 권장)
OPENAI_API_KEY=your_openai_api_key_here
# LLM 모델 선택 (기본값: gpt-4o)
WREN_LLM_MODEL=gpt-4o
# Wren UI 포트 (기본값: 3000)
WREN_UI_PORT=3000
